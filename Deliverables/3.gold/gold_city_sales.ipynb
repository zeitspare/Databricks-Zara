   "source": [
    "%sql\n",
    "SELECT\n",
    "    fs.city,\n",
    "    SUM(fs.pieces_sold) AS total_volume,\n",
    "    ROUND(SUM(fs.net_revenue),2) AS total_revenue,\n",
    "    AVG(fs.discount) AS avg_discount\n",
    "FROM zara_lakehouse.retail_silver.fact_sales_silver fs\n",
    "GROUP BY fs.city;"
   ]
  }
